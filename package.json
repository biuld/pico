{
  "name": "pico",
  "version": "0.1.0",
  "type": "module",
  "description": "A terminal tool that rides on Codex's harness with autonomous persistence and branch management",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "compile": "bun run scripts/build.ts --compile",
    "test": "bun test",
    "typecheck": "bun run scripts/typecheck.ts",
    "check": "bun run typecheck && bun test",
    "sync:codex-protocol": "bun run scripts/sync-codex-app-server-protocol.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.2.6",
    "@opentui/solid": "^0.2.6",
    "@pico/codex-app-server-protocol": "workspace:*",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
